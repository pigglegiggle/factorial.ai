# Example Environment Variables
# Copy this file to .env.local and fill in your actual values

# Database Configuration
# Get this from your Neon dashboard after creating a database
DATABASE_URL="postgresql://username:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Google Gemini API Configuration  
# Get this from https://makersuite.google.com/app/apikey
GEMINI_API_KEY="AIzaSyC-your-gemini-api-key-here"

# JWT Secret for Authentication
# Generate a strong random string (at least 32 characters)
JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long"

# Environment
NODE_ENV="development"

# Optional: NextAuth configuration if you decide to use NextAuth.js instead
# NEXTAUTH_SECRET="your-nextauth-secret"
# NEXTAUTH_URL="http://localhost:3000"
